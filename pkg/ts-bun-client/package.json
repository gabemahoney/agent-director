{
  "name": "@CHANGEME-H3/agent-director",
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "bun": ">=1.0.21"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/**/*.test.*",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "bun run build.ts",
    "lint": "eslint src/ --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "optionalDependencies": {
    "@CHANGEME-H3/agent-director-linux-x64": "0.0.0",
    "@CHANGEME-H3/agent-director-darwin-x64": "0.0.0",
    "@CHANGEME-H3/agent-director-darwin-arm64": "0.0.0"
  },
  "devDependencies": {
    "typescript": ">=5.2.0",
    "bun-types": "latest",
    "eslint": "^8.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0"
  }
}

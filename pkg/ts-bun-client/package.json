{
  "name": "agent-director",
  "version": "0.7.6",
  "type": "module",
  "os": ["linux", "darwin"],
  "cpu": ["x64", "arm64"],
  "engines": {
    "bun": ">=1.0.21"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/version-floor.json",
    "!dist/**/*.test.*",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./dist/version-floor.json": "./dist/version-floor.json"
  },
  "scripts": {
    "build": "bun run build.ts",
    "lint": "eslint src/ --ext .ts",
    "typecheck": "tsc --noEmit --project tsconfig.typecheck.json",
    "test": "bun test",
    "smoke": "bun test test/smoke/ test/smoke-invariants.test.ts",
    "envelope-diff": "bun test test/envelope-diff.test.ts test/envelope-diff-invariants.test.ts",
    "version-bump-publish": "bun run scripts/version-bump.ts",
    "verify-installed-pkg": "bun run scripts/verify-installed-pkg.ts"
  },
  "devDependencies": {
    "typescript": ">=5.2.0",
    "bun-types": "latest",
    "eslint": "^8.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0"
  }
}
